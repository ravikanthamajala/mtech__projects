        "model = api.load(\"glove-wiki-gigaword-100\")\n",
        "\n",
        "print(model.most_similar(positive=[\"woman\",\"king\"],negative=[\"man\"]))\n",
        "print(model.most_similar(positive=[\"female\",\"doctor\"],negative=[\"male\"]))"
