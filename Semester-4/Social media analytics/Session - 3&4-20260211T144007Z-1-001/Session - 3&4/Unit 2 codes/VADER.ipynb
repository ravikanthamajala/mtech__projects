        "analyzer = SentimentIntensityAnalyzer()\n",
        "\n",
        "text = \"I absolutely love this product, but the battery life is terrible!\"\n",
        "\n",
        "scores = analyzer.polarity_scores(text)\n",
        "\n",
        "print(scores)"
